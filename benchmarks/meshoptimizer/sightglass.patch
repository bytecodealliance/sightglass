 #include <time.h>
+#include <unistd.h>
+
+// The grid size N (which drives the mesh size, and thus the workload) is read
+// from disk so it can be tuned without recompiling.
+static int read_int_from_file(const char* path)
+{
+	char buf[64] = {0};
+	int fd = open(path, O_RDONLY);
+	assert(fd != -1);
+
+	size_t m = 0, n = 0;
+	do {
+		m = read(fd, buf + n, sizeof(buf) - n - 1);
+		assert((long)m >= 0);
+		n += m;
+	} while (m > 0 && n < sizeof(buf) - 1);
+	assert(close(fd) == 0);
+
+	buf[n] = '\0';
+	return atoi(buf);
+}
 
